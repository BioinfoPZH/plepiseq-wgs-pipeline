{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/db_update_run_report.schema.v1.1.0.json",
  "title": "Database Update Run Report V. 1.1.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "database",
    "execution_context",
    "run_id",
    "started_at",
    "finished_at",
    "runtime_seconds",
    "run_status",
    "update_decision",
    "source",
    "log_file",
    "milestones"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this JSON report schema.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "examples": ["1.1.1"]
    },

    "database": {
      "$ref": "#/$defs/database_identity"
    },

    "execution_context": {
      "type": "object",
      "additionalProperties": false,
      "description": "Execution context and key inputs used for this update run.",
      "required": ["workspace", "user", "container_image", "host"],
      "properties": {
        "workspace": {
          "type": "string",
          "description": "Local working directory used by the updater (download/build happens here)."
        },
        "user": {
          "type": "string",
          "description": "User account that executed the update."
        },
        "host": {
          "type": "string",
          "description": "Hostname of the system where the update ran."
        },
        "container_image": {
          "type": "string",
          "description": "Container image reference used to run the update (tag or digest)."
        }
      }
    },

    "run_id": {
      "type": "string",
      "minLength": 8,
      "description": "Unique identifier of this run (e.g., timestamp + database name)."
    },

    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Run start time (ISO 8601)."
    },
    "finished_at": {
      "type": "string",
      "format": "date-time",
      "description": "Run end time (ISO 8601)."
    },

    "runtime_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Total run duration in seconds."
    },

    "run_status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "SKIPPED"],
      "description": "Overall result: PASS (updated successfully), SKIPPED (nothing to do / not applicable), FAIL (update did not complete)."
    },

    "update_decision": {
      "type": "object",
      "additionalProperties": false,
      "description": "Decision and evidence used by the update mechanism.",
      "required": ["mode", "result", "message"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["checksum_manifest", "version_endpoint", "timestamp", "always_rebuild"],
          "description": "How the updater decides whether an update is needed."
        },
        "result": {
          "type": "string",
          "enum": ["updated", "latest_version_present", "always_rebuild", "error"],
          "description": "Outcome of the update decision."
        },
        "message": {
          "type": "string",
          "description": "Short human-readable summary of the decision."
        },

        "checksums_before": {
          "$ref": "#/$defs/checksum_list",
          "description": "Checksums observed at the start of the run (for relevant reference files)."
        },
        "checksums_after": {
          "$ref": "#/$defs/checksum_list",
          "description": "Checksums observed at the end of the run (for relevant reference files)."
        },

        "timestamp_local": {
          "type": "string",
          "description": "Local timestamp used for comparison (ISO 8601 recommended)."
        },
        "timestamp_remote": {
          "type": "string",
          "description": "Remote timestamp used for comparison (ISO 8601 recommended)."
        },

        "version_local": {
          "type": "string",
          "description": "Local database version string."
        },
        "version_remote": {
          "type": "string",
          "description": "Remote database version string."
        },
        "first_build": {
          "type": "boolean",
          "default": false,
          "description": "True if there was no local checksum baseline at the start (e.g., missing manifest). When true, checksums_before may be an empty list."
}
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "checksum_manifest" } } },
          "then": { "required": ["checksums_before", "checksums_after"] }
        },
        {
          "if": { "properties": { "mode": { "const": "version_endpoint" } } },
          "then": { "required": ["version_local", "version_remote"] }
        },
        {
          "if": { "properties": { "mode": { "const": "timestamp" } } },
          "then": { "required": ["timestamp_local", "timestamp_remote"] }
        }
      ]
    },

    "source": {
      "$ref": "#/$defs/source",
      "description": "Information about where the database comes from and which files are expected."
    },

    "log_file": {
      "type": "string",
      "description": "Path to the raw log file produced during this run."
    },

    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/milestone" },
      "description": "Ordered list of major steps attempted by the updater."
    },

    "error": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional structured error details (mainly useful when run_status=FAIL).",
      "properties": {
        "code": { "type": "string", "description": "Short machine-friendly error code." },
        "message": { "type": "string", "description": "Human-readable error summary." },
        "retry_recommended": { "type": "boolean", "description": "Whether a retry is likely to succeed." }
      }
    }
  },

  "$defs": {
    "database_identity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Database identifier and optional category/description.",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Database name (stable identifier).",
          "examples": ["vfdb", "cgmlst", "kraken2_db"]
        },
        "category": {
          "type": "string",
          "description": "Optional high-level category or short description.",
          "examples": ["virulence", "typing", "taxonomy"]
        }
      }
    },

    "checksum_list": {
      "type": "array",
      "description": "List of file checksums (MD5: 32 hex, SHA-256: 64 hex).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file_name", "checksum"],
        "properties": {
          "file_name": {
            "type": "string",
            "minLength": 1,
            "description": "File name or path (as recorded by the updater)."
          },
          "checksum": {
            "type": "string",
            "description": "MD5 (32 hex) or SHA-256 (64 hex).",
            "pattern": "^(?:[a-fA-F0-9]{32}|[a-fA-F0-9]{64})$"
          }
        }
      }
    },

    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "reference", "expected_raw_files", "expected_processed_files"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["https", "ftp", "s3", "git", "rsync", "local"],
          "description": "Source type used to retrieve the database."
        },
        "reference": {
          "type": "string",
          "description": "Base URL or path used for availability checks and/or downloads."
        },
        "expected_raw_files": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Expected file names/paths after download (before processing)."
        },
        "expected_processed_files": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Expected file names/paths after processing/indexing."
        }
      }
    },

    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "PREFLIGHT_CONNECTIVITY",
            "DATABASE_AVAILABILITY",
            "UPDATE_STATUS",
            "REMOTE_FILES_DOWNLOAD_STATUS",
            "PROCESSING_STATUS",
            "FINAL_STATUS"
          ],
          "description": "Milestone name (high-level step)."
        },
        "status": {
          "type": "string",
          "enum": ["PASSED", "FAILED", "SKIPPED"],
          "description": "Result of this milestone."
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "Milestone start time (ISO 8601)."
        },
        "finished_at": {
          "type": "string",
          "format": "date-time",
          "description": "Milestone end time (ISO 8601)."
        },
        "attempts": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Number of attempts for this milestone (e.g., retries)."
        },
        "retryable": {
          "type": "boolean",
          "default": false,
          "description": "Whether this milestone supports retries."
        },
        "message": {
          "type": "string",
          "description": "Short human-readable message for this milestone."
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional metrics (counts, sizes, durations, etc.)."
        }
      }
    }
  }
}

